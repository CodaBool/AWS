{
  "agent": {
    "logfile": "/opt/aws/amazon-cloudwatch-agent/logs/amazon-cloudwatch-agent.log"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/server/logs.log",
            "log_group_name": "/server/",
            "log_stream_name": "logs"
          }
        ]
      }
    },
    "log_stream_name": "logs"
  }
}